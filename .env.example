# ========== LLM API ==========
# 推荐使用 OpenRouter（支持 Claude、GPT、Llama 等）
# 获取 key: https://openrouter.ai/settings/keys
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=anthropic/claude-3.5-sonnet

# 可选：实体提取专用的快速/低成本模型（不配置则使用主模型）
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=https://openrouter.ai/api/v1
# LLM_BOOST_MODEL_NAME=meta-llama/llama-3.1-70b-instruct

# ========== Neo4j 图数据库 ==========
# Railway 私有网络（后端与 Neo4j 在同一 Railway 项目中）：
NEO4J_URI=bolt://noderamfneo4j.railway.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_strong_password_here

# 本地开发（Docker）：
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_local_password_here
